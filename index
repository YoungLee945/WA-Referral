                        )}

                        {/* Backend View */}
                        {view === 'backend' && (
                            <div className="animate-enter">
                                <div className="flex justify-between items-center mb-8">
                                    <div><h2 className="text-2xl font-bold text-slate-800">{t('back_title')}</h2><p className="text-slate-500 text-sm">Yang (ID: 9921)</p></div>
                                    <button className="px-4 py-2 border bg-white rounded-lg font-bold text-sm flex items-center gap-2 shadow-sm"><Icons.Download size={16}/> Report</button>
                                </div>
                                <div className="hidden md:block bg-white rounded-xl border shadow-sm overflow-hidden">
                                    <table className="w-full text-left">
                                        <thead className="bg-slate-50 border-b">
                                            <tr>
                                                {['th_case','th_needs','th_severity','th_status','th_action'].map(k => <th key={k} className="p-5 font-semibold text-slate-500 text-sm">{t(k)}</th>)}
                                            </tr>
                                        </thead>
                                        <tbody className="divide-y">
                                            {caseload.map(c => (
                                                <tr key={c.id} className="hover:bg-slate-50/50 transition-colors">
                                                    <td className="p-5"><div className="font-bold">Case {c.id}</div><div className="text-xs text-slate-400">{c.location}</div></td>
                                                    <td className="p-5 text-sm text-slate-600">{c.needs}</td>
                                                    <td className="p-5"><button onClick={() => toggleSeverity(c.id)} className={`px-3 py-1 rounded-full text-xs font-bold uppercase ${sevColors[c.severity]}`}>{t('sev_'+c.severity)}</button></td>
                                                    <td className="p-5"><span className={`px-3 py-1 rounded-full text-xs font-bold uppercase border ${c.status === 'Closed' ? 'bg-emerald-50 text-emerald-700 border-emerald-100' : 'bg-orange-50 text-orange-700 border-orange-100'}`}>{c.status}</span></td>
                                                    <td className="p-5 flex gap-2"><button onClick={() => nav('assessment')} className="px-3 py-1.5 bg-blue-600 text-white text-xs font-bold rounded">Open</button><button onClick={() => {setActiveCaseId('Case '+c.id); setNotesOpen(true)}} className="p-1.5 text-slate-400 hover:text-blue-600"><Icons.StickyNote size={16}/></button></td>
                                                </tr>
                                            ))}
                                        </tbody>
                                    </table>
                                </div>
                                {/* Mobile Cards */}
                                <div className="md:hidden space-y-4">
                                    {caseload.map(c => (
                                        <div key={c.id} className="bg-white p-5 rounded-xl border shadow-sm">
                                            <div className="flex justify-between mb-2">
                                                <div className="font-bold text-lg">Case {c.id}</div>
                                                <button onClick={() => toggleSeverity(c.id)} className={`px-2 py-1 rounded text-xs font-bold uppercase ${sevColors[c.severity]}`}>{t('sev_'+c.severity)}</button>
                                            </div>
                                            <div className="text-sm text-slate-500 mb-4">{c.needs}</div>
                                            <button onClick={() => nav('assessment')} className="w-full py-2 bg-blue-600 text-white rounded-lg font-bold text-sm">Continue</button>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        )}

                        {/* Assessment View */}
                        {view === 'assessment' && (
                            <div className="animate-enter">
                                <button onClick={() => nav('backend')} className="mb-6 text-slate-400 hover:text-slate-600 text-sm font-bold flex items-center gap-2"><Icons.ChevronRight size={16} className="rotate-180"/> Back</button>
                                <div className="flex justify-between items-center mb-8">
                                    <h2 className="text-3xl font-bold text-slate-800">{t('assess_title')}: <span className="text-blue-600">Case 123</span></h2>
                                </div>
                                <div className="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
                                    <div className="bg-white rounded-xl shadow-sm border p-8">
                                        <p className="text-slate-500 mb-6 pb-4 border-b">{t('assess_intro')}</p>
                                        <div className="space-y-4">
                                            {NEEDS_CONFIG.map(group => {
                                                const isExpanded = expandedDomains.includes(group.id);
                                                const selectedCount = group.subCategories.filter(s => selectedSubNeeds.includes(s.id)).length;
                                                return (
                                                    <div key={group.id} className={`border rounded-lg transition-all ${isExpanded ? 'border-blue-200 bg-blue-50/30' : 'hover:border-slate-300'}`}>
                                                        <div onClick={() => toggleDomain(group.id)} className="flex justify-between items-center p-4 cursor-pointer select-none">
                                                            <div className="flex items-center gap-3">
                                                                <div className={`p-2 rounded-lg ${isExpanded ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-500'}`}><group.icon size={20}/></div>
                                                                <div>
                                                                    <div className={`font-bold ${isExpanded ? 'text-blue-800' : 'text-slate-700'}`}>{group.title}</div>
                                                                    {selectedCount > 0 && <div className="text-xs text-blue-600 font-bold">{selectedCount} selected</div>}
                                                                </div>
                                                            </div>
                                                            <Icons.ChevronDown size={20} className={`text-slate-400 transition-transform ${isExpanded ? 'rotate-180' : ''}`}/>
                                                        </div>
                                                        {isExpanded && (
                                                            <div className="px-4 pb-4 pl-14 space-y-2 animate-fade-in">
                                                                {group.subCategories.map(sub => (
                                                                    <label key={sub.id} className="flex items-center gap-3 p-2 rounded hover:bg-blue-100/50 cursor-pointer transition">
                                                                        <input type="checkbox" checked={selectedSubNeeds.includes(sub.id)} onChange={() => handleSubNeedToggle(sub.id)} className="w-5 h-5 rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                                                                        <span className="text-sm font-medium text-slate-700">{sub.label}</span>
                                                                    </label>
                                                                ))}
                                                            </div>
                                                        )}
                                                    </div>
                                                )
                                            })}
                                        </div>
                                        <button onClick={() => nav('results')} disabled={selectedSubNeeds.length === 0} className={`w-full mt-8 py-4 rounded-xl font-bold shadow-lg flex items-center justify-center gap-2 text-lg transition-all ${selectedSubNeeds.length === 0 ? 'bg-slate-200 text-slate-400 cursor-not-allowed' : 'bg-blue-600 hover:bg-blue-700 text-white'}`}>
                                            {t('btn_match')} <Icons.ArrowRight size={20}/>
                                        </button>
                                    </div>
                                    <div className="hidden lg:block h-[600px] rounded-xl overflow-hidden shadow-lg relative">
                                        <img src="https://images.unsplash.com/photo-1544027993-37dbfe43562a?auto=format&fit=crop&w=1000&q=80" className="w-full h-full object-cover" />
                                        <div className="absolute inset-0 bg-blue-900/20"></div>
                                    </div>
                                </div>
                            </div>
                        )}

                        {/* Results View */}
                        {view === 'results' && (
                            <div className="animate-enter">
                                <div className="flex justify-between items-center mb-8">
                                    <h2 className="text-2xl font-bold text-slate-800">{t('res_title')}</h2>
                                    <div className="flex gap-3">
                                        <button onClick={() => setFiltersVisible(!filtersVisible)} className="lg:hidden px-4 py-2 border bg-white rounded-lg font-bold shadow-sm flex gap-2"><Icons.Filter size={18}/> {filtersVisible ? t('hide_filters') : t('show_filters')}</button>
                                        {basket.length > 0 && <button onClick={() => nav('basket')} className="px-6 py-2 bg-blue-600 text-white rounded-lg font-bold shadow-lg flex gap-2 items-center hover:bg-blue-700 transition">{t('btn_proceed')} <Icons.ChevronRight size={18}/></button>}
                                    </div>
                                </div>
                                <div className="grid grid-cols-1 lg:grid-cols-[300px_1fr] gap-8 items-start">
                                    {/* Filters */}
                                    <div className={`bg-white rounded-xl border p-6 shadow-sm ${filtersVisible ? 'block' : 'hidden lg:block sticky top-24'}`}>
                                        <h3 className="font-bold text-lg mb-6 flex gap-2 items-center"><Icons.Briefcase size={18} className="text-blue-500"/> {t('fil_title')}</h3>
                                        <div className="space-y-6">
                                            <div><div className="text-xs font-bold text-slate-400 uppercase mb-3">{t('fil_loc')}</div><select className="w-full p-3 border rounded-lg text-sm bg-white"><option>Perth Metro</option><option>Statewide</option></select></div>
                                            {[
                                                {title: t('fil_avail'), items: ['Immediate', 'Waitlist']},
                                                {title: t('fil_cost'), items: ['Free', 'Low Cost']},
                                                {title: t('fil_cul'), items: ['CaLD Specialist', 'Interpreter', 'Indigenous Focus']}
                                            ].map((g, i) => (
                                                <div key={i}><div className="text-xs font-bold text-slate-400 uppercase mb-3">{g.title}</div><div className="space-y-2">{g.items.map((item, idx) => <label key={idx} className="flex gap-2 items-center text-sm text-slate-600"><input type="checkbox" className="w-4 h-4 rounded text-blue-600"/>{item}</label>)}</div></div>
                                            ))}
                                        </div>
                                    </div>
                                    {/* Results */}
                                    <div className="space-y-8">
                                        {matchedAgencies.length === 0 ? (
                                            <div className="bg-slate-50 border border-dashed rounded-xl p-12 text-center text-slate-500"><Icons.Search size={48} className="mx-auto mb-4 opacity-20"/><p>No matches found.</p></div>
                                        ) : (
                                            matchedAgencies.map(agency => (
                                                <div key={agency.id} className="bg-white rounded-xl border shadow-sm hover:shadow-lg transition overflow-hidden">
                                                    <div className="p-6 md:p-8 flex flex-col md:flex-row gap-6 border-b bg-slate-50/50">
                                                        <div className={`w-20 h-20 rounded-2xl ${agency.color} flex items-center justify-center text-4xl shrink-0 shadow-inner`}><agency.icon /></div>
                                                        <div className="flex-1">
                                                            <div className="flex flex-col md:flex-row justify-between items-start mb-2">
                                                                <div><h3 className="text-2xl font-bold text-slate-900">{agency.name}</h3><div className="flex items-center gap-2 mt-1 text-slate-500 text-sm"><Icons.MapPin size={14}/> {agency.location}</div></div>
                                                                <div className="flex gap-2 mt-2 md:mt-0"><a href={`tel:${agency.phone}`} className="px-3 py-1.5 bg-white border rounded font-bold text-xs flex gap-1 items-center"><Icons.Phone size={12}/> {agency.phone}</a><a href={agency.website} target="_blank" className="px-3 py-1.5 bg-white border rounded font-bold text-xs flex gap-1 items-center"><Icons.Globe size={12}/> Web</a></div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div className="divide-y">
                                                        {agency.matchingPrograms.map(prog => (
                                                            <div key={prog.id} className="p-6 md:p-8 hover:bg-blue-50/30 transition">
                                                                <div className="flex justify-between gap-4 mb-3">
                                                                    <h4 className="text-lg font-bold text-blue-700 flex gap-2 items-center">{prog.title}</h4>
                                                                    <span className={`px-3 py-1 rounded-full text-xs font-bold border self-start ${prog.availability.includes('Immediate') ? 'bg-emerald-100 text-emerald-800 border-emerald-200' : 'bg-amber-100 text-amber-800 border-amber-200'}`}>{prog.availability}</span>
                                                                </div>
                                                                <p className="text-slate-600 text-sm mb-4">{prog.description}</p>
                                                                <div className="flex flex-col md:flex-row justify-between items-center gap-4">
                                                                    <div className="text-xs bg-slate-100 px-3 py-2 rounded border text-slate-500"><strong>Elig:</strong> {prog.eligibility}</div>
                                                                    <button onClick={() => addToBasket(prog.id)} disabled={basket.includes(prog.id)} className={`px-6 py-2.5 rounded-lg text-sm font-bold transition flex gap-2 items-center shadow-sm ${basket.includes(prog.id) ? 'bg-emerald-600 text-white cursor-default' : 'bg-white border text-slate-700 hover:border-blue-600 hover:text-blue-600'}`}>
                                                                        {basket.includes(prog.id) ? <><Icons.Check size={16}/> {t('btn_added')}</> : <><Icons.CheckCircle size={16}/> {t('btn_add')}</>}
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        ))}
                                                    </div>
                                                </div>
                                            ))
                                        )}
                                    </div>
                                </div>
                            </div>
                        )}

                        {/* Basket View */}
                        {view === 'basket' && (
                            <div className="animate-enter">
                                <h2 className="text-2xl font-bold text-slate-800 mb-8">Referral Basket: Case 123</h2>
                                <div className="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
                                    <div>
                                        <div className="bg-orange-50 border border-orange-200 rounded-xl p-6 mb-6 flex gap-4 items-center">
                                            <div className="bg-orange-100 p-3 rounded-full text-orange-600 shrink-0"><Icons.Lock size={24}/></div>
                                            <div><strong className="block text-orange-800 text-lg">{t('warn_title')}</strong><p className="text-orange-700 text-sm">{t('warn_msg')}</p></div>
                                        </div>
                                        <div className="space-y-4">
                                            {basket.length === 0 ? <div className="text-center p-10 text-slate-400 italic bg-white rounded-xl border border-dashed">{t('empty_basket')}</div> : basket.map(id => {
                                                const agency = SERVICES_DB.find(a => a.programs.some(p => p.id === id));
                                                const prog = agency?.programs.find(p => p.id === id);
                                                if(!prog) return null;
                                                return (
                                                    <div key={id} className="bg-white p-6 rounded-xl border shadow-sm flex justify-between items-center animate-fade-in">
                                                        <div className="flex items-center gap-4">
                                                            <div className={`w-12 h-12 rounded-lg ${agency.color} flex items-center justify-center text-xl shrink-0`}><agency.icon size={20}/></div>
                                                            <div><span className="font-bold text-slate-800 text-lg block">{agency.name}</span><span className="text-sm text-blue-600 font-semibold">{prog.title}</span></div>
                                                        </div>
                                                        <a href={agency.website} target="_blank" className="px-4 py-2 bg-blue-600 text-white rounded-lg font-bold text-sm hover:bg-blue-700 transition flex items-center gap-2">{t('open_portal')} <Icons.ExternalLink size={14}/></a>
                                                    </div>
                                                )
                                            })}
                                        </div>
                                    </div>
                                    <div className="hidden lg:block h-[400px] rounded-xl overflow-hidden shadow-lg relative">
                                        <img src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&w=800&q=80" className="w-full h-full object-cover" />
                                    </div>
                                </div>
                            </div>
                        )}

                        {/* Notes Modal */}
                        {notesOpen && (
                            <div className="fixed inset-0 bg-slate-900/60 z-[3000] flex items-center justify-center p-4 animate-fade-in">
                                <div className="bg-white w-full max-w-[450px] rounded-xl p-8 shadow-2xl">
                                    <div className="flex justify-between mb-6"><h3 className="text-blue-600 font-bold text-xl flex gap-2 items-center"><Icons.StickyNote size={20}/> {t('note_title')}</h3><button onClick={() => setNotesOpen(false)}><Icons.X size={20} className="text-slate-400"/></button></div>
                                    <div className="mb-4 font-bold text-slate-700">{activeCaseId}</div>
                                    <textarea 
                                        id="case-notes" 
                                        className="w-full h-32 p-4 border rounded-lg resize-none mb-4 bg-slate-50" 
                                        placeholder="Add non-identifying notes here..."
                                    ></textarea>
                                    <div className="bg-orange-50 text-orange-700 p-3 rounded-md text-xs mb-6 flex gap-2 items-start"><Icons.AlertTriangle size={14} className="mt-0.5 shrink-0"/><span>{t('note_warn')}</span></div>
                                    <div className="flex justify-end gap-3">
                                        <button onClick={() => setNotesOpen(false)} className="px-4 py-2 border rounded text-slate-600 hover:bg-slate-50">{t('btn_cancel')}</button>
                                        <button onClick={async () => { 
                                            const notes = document.getElementById('case-notes').value;
                                            if (user) {
                                                await saveNotes(activeCaseId, notes);
                                            } else {
                                                alert("Notes saved locally.");
                                            }
                                            setNotesOpen(false); 
                                        }} className="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">{t('btn_save')}</button>
                                    </div>
                                </div>
                            </div>
                        )}

                    </main>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
